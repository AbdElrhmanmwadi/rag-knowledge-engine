APP_NAME=Voxora
APP_DESCRIPTION=Voxora AI API
APP_VERSION=1.0.0
FILE_MAX_SIZE=104857600
FILE_DEFAULT_CHUNK_SIZE=1048576

POSTGRES_USERNAME=voxora
POSTGRES_PASSWORD=change-me
POSTGRES_DB=voxora

GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me
PUBLIC_BASE_URL=http://localhost
PUBLIC_API_BASE_URL=/api
HTTP_PORT=80

GENERATION_BACKEND=OPENAI
EMBEDDING_BACKEND=OPENAI
OPENAI_API_KEY=
OPENAI_API_URL=
COHERE_API_KEY=
GENERATION_MODEL_ID=
EMBEDDING_MODEL_ID=
EMBEDDING_MODEL_SIZE=1536
INPUT_DAFAULT_MAX_CHARACTERS=4000
GENERATION_DAFAULT_MAX_TOKENS=1024
GENERATION_DAFAULT_TEMPERATURE=0.2

TRANSLATION_ENGINE=LIBRETRANSLATE
TRANSLATION_API_KEY=
TRANSLATION_TIMEOUT_SECONDS=60
TRANSLATION_MAX_RETRIES=2
TRANSLATION_RETRY_BACKOFF_SECONDS=1.0
DEFAULT_TARGET_LANG=ar

VECTOR_DB_BACKEND=PGVECTOR
VECTOR_DB_BACKEND_LITERAL=["PGVECTOR"]
VECTOR_DB_PGVEC_INDEX_THRESHOLD=50
VECTOR_DB_PATH=
VECTOR_DB_DISTANCE_METHOD=cosine

STORAGE_ROOT=/app/src/assets
PRIMARY_LANG=en
DEFAULT_LANG=en

STT_BACKEND=FASTER_WHISPER
STT_MODEL_SIZE=small
STT_DEVICE=cpu
STT_COMPUTE_TYPE=int8
STT_TIMEOUT_SECONDS=180
STT_WARMUP_ON_STARTUP=true
STT_WARMUP_TIMEOUT_SECONDS=1000

TTS_BACKEND=PIPER
PIPER_EXE_PATH=
PIPER_MODEL_PATH=
FFMPEG_PATH=/usr/bin/ffmpeg
FFMPEG_TIMEOUT_SECONDS=60

JWT_SECRET_KEY=replace-with-a-strong-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=14
EMAIL_VERIFICATION_TOKEN_EXPIRE_HOURS=24
RESEND_API_KEY=re_replace_with_resend_api_key
RESEND_FROM_EMAIL=Voxora <noreply@your-domain.com>
FRONTEND_BASE_URL=https://your-domain.com

AGENT_DEFAULT_RETRIEVAL_LIMIT: int = 5
AGENT_MAX_TOOL_STEPS: int = 4
AGENT_MAX_OUTPUT_TOKENS: int = 500
