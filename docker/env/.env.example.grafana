# Grafana service config. Copy to .env.grafana.
# Grafana is served behind Nginx at /grafana/ — the sub-path settings make that work.
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=change_me
GF_SERVER_ROOT_URL=http://localhost/grafana/
GF_SERVER_SERVE_FROM_SUB_PATH=true
GF_USERS_ALLOW_SIGN_UP=false
# Used by the provisioned Postgres datasource (feedback analytics). Must match .env.postgres.
POSTGRES_PASSWORD=change_me
